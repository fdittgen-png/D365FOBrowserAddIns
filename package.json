{
  "name": "d365fo-browser-addins",
  "version": "0.1.0",
  "description": "Chromium browser extension that records reproduction scenarios for Dynamics 365 Finance & Operations and exports them as a self-contained XML bundle or as a ticket in an external tracker.",
  "license": "MIT",
  "author": "Frank Dittgen",
  "homepage": "https://github.com/fdittgen-png/D365FOBrowserAddIns",
  "repository": {
    "type": "git",
    "url": "https://github.com/fdittgen-png/D365FOBrowserAddIns.git"
  },
  "bugs": {
    "url": "https://github.com/fdittgen-png/D365FOBrowserAddIns/issues"
  },
  "keywords": [
    "dynamics-365",
    "d365fo",
    "browser-extension",
    "chrome-extension",
    "edge-extension",
    "manifest-v3",
    "bug-reporting",
    "repro-recorder"
  ],
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky",
    "build": "node scripts/build.mjs",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "check:size": "node scripts/check-bundle-size.mjs",
    "package:store": "node scripts/package-store.mjs",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "release": "node scripts/release.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/adm-zip": "^0.5.8",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.9",
    "adm-zip": "^0.5.17",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml,mjs,js}": [
      "prettier --write"
    ]
  }
}
